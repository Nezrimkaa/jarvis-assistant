# ============================================================
# J.A.R.V.I.S. — Персональный ИИ-ассистент
# ============================================================

# Имя ассистента
BOT_NAME=Джарвис

# Голос (true/false)
VOICE_ENABLED=true

# Пол голоса: male, female или jarvis
VOICE_GENDER=jarvis

# ============================================================
# AI Провайдер: ollama, gemini или groq (все бесплатные!)
# ============================================================
AI_PROVIDER=ollama

# --- Ollama (локальная модель, полностью бесплатно) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# --- Google Gemini (бесплатный tier, до 60 запросов/мин) ---
# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# --- Groq (бесплатный tier, очень быстрые модели) ---
# Получить ключ: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ============================================================
# Голосовая активация
# ============================================================
WAKE_WORD_ENABLED=true
WAKE_WORD_COOLDOWN=4.0

# ============================================================
# Системный трей
# ============================================================
TRAY_ENABLED=true

# ============================================================
# Автозапуск с Windows
# ============================================================
AUTOSTART_ENABLED=false

# ============================================================
# Размеры окна
# ============================================================
WINDOW_WIDTH=500
WINDOW_HEIGHT=750
WINDOW_MIN_WIDTH=400
WINDOW_MIN_HEIGHT=500

# ============================================================
# Telegram бот (удаленное управление)
# ============================================================
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=

# ============================================================
# Прокси (если нужен)
# ============================================================
PROXY_URL=
